{
  "name": "halftone",
  "version": "0.1.0",
  "description": "The Claude Code plugin for award-tier expressive web design. No shadcn. No Inter. No purple gradients.",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "halftone": "dist/index.js" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "build:index": "bun run src/patterns/build-index.ts"
  },
  "keywords": ["claude-code", "claude-code-plugin", "web-design", "sveltekit", "astro", "design-system", "anti-ai-slop", "craft"],
  "author": "Sakaax",
  "license": "AGPL-3.0",
  "repository": { "type": "git", "url": "https://github.com/Sakaax/halftone" },
  "dependencies": {
    "gray-matter": "4.0.3",
    "zod": "3.22.4",
    "postcss": "8.4.33",
    "node-html-parser": "6.1.12"
  },
  "devDependencies": {
    "typescript": "5.8.0",
    "@types/node": "20.11.0",
    "@playwright/test": "1.41.0",
    "@axe-core/playwright": "4.8.2",
    "prettier": "3.2.4"
  },
  "peerDependencies": {
    "playwright": "1.41.0"
  },
  "peerDependenciesMeta": {
    "playwright": { "optional": true }
  }
}
